<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MyToDoList.ViewModels"
		xmlns:models="using:MyToDoList.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		Width="500" Height="600"
        x:Class="MyToDoList.Views.GroupsWindow"
		x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Groups">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <StackPanel Margin="10 10">
        <TextBlock Text="To-Do List" Margin="5 5" FontSize="25" FontFamily="Faberge" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        
        <ListBox ItemsSource="{Binding Groups}" 
                 SelectedItem="{Binding SelectedGroup}"
                 Margin="0,10">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" Spacing="5"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
                <Style Selector="ListBoxItem > Border">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Style>
                <Style Selector="ListBoxItem:selected > Border">
                    <Setter Property="Background" Value="#4CAF50"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover > Border">
                    <Setter Property="Background" Value="#BDBDBD"/>
                </Style>
                <Style Selector="ListBoxItem:selected TextBlock">
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </ListBox.Styles>

			<ListBox.ItemTemplate>
				<DataTemplate x:DataType="models:TaskGroup">
					<Border Padding="15,8" CornerRadius="20">
						<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
							<TextBlock Text="{Binding Name}" FontFamily="Faberge"/>
						</StackPanel>

						<Border.ContextMenu>
							<ContextMenu>
								<MenuItem Header="Delete Group"
										  FontFamily="Faberge"
										  Command="{Binding $parent[Window].DataContext.RemoveGroupCommand}"
										  CommandParameter="{Binding}"/>
							</ContextMenu>
						</Border.ContextMenu>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
    

</Window>
